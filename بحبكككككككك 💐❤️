<!DOCTYPE html>
<html lang="ar">
<head>
<meta charset="UTF-8">
<title>أنا و أنتي ❤️</title>

<style>
body {
  margin: 0;
  padding: 0;
  background: linear-gradient(135deg, #ff9a9e, #fad0c4);
  font-family: Arial;
  text-align: center;
  color: white;
  overflow: hidden;
}

h1 {
  margin-top: 50px;
  font-size: 40px;
}

p {
  font-size: 20px;
}

button {
  padding: 12px 25px;
  background: white;
  color: #ff4d88;
  border: none;
  border-radius: 20px;
  font-size: 18px;
}

#msg {
  margin-top: 20px;
  font-size: 22px;
}

/* قلوب متحركة */
.heart {
  position: fixed;
  bottom: -10px;
  color: red;
  animation: float 5s linear infinite;
}

@keyframes float {
  0% {transform: translateY(0);}
  100% {transform: translateY(-100vh);}
}
</style>

</head>

<body>

<h1>❤️ أحمد & [منه] ❤️</h1>
<p>من يوم ما عرفتك، حياتي بقت أحلى 💖</p>

<p id="time"></p>

<button onclick="showMessage()">اضغطي هنا 💌</button>
<p id="msg"></p>

<script>
// رسالة
function showMessage() {
  document.getElementById("msg").innerHTML = "بحبك جدًا ومش متخيل حياتي من غيرك ❤️";
}

// عداد الحب
let startDate = new Date("2026-01-29"); // غير التاريخ ده
function updateTime() {
  let now = new Date();
  let diff = now - startDate;
  let days = Math.floor(diff / (1000 * 60 * 60 * 24));
  document.getElementById("time").innerHTML = "بقالنا " + days + " يوم سوا ❤️";
}
setInterval(updateTime, 1000);

// قلوب متحركة
setInterval(() => {
  let heart = document.createElement("div");
  heart.className = "heart";
  heart.innerHTML = "❤️";
  heart.style.left = Math.random() * 100 + "vw";
  heart.style.fontSize = (Math.random() * 20 + 10) + "px";
  document.body.appendChild(heart);

  setTimeout(() => {
    heart.remove();
  }, 5000);
}, 300);

</script>

</body>
</html>
